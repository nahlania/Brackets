  <diagram name="BracketWise Engine Simplified" id="bw-simple">
    <mxGraphModel dx="1044" dy="635" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="1600" background="light-dark(#FFFFFF,#E8E8E8)" math="0" shadow="0">
      <root>
