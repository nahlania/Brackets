        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="1  .  INCOME SOURCES" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="20" as="geometry" />
        </mxCell>
        <mxCell id="t4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=11;" value="T4 Employment Income" vertex="1">
          <mxGeometry height="50" width="220" x="20" y="62" as="geometry" />
        </mxCell>
        <mxCell id="se" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=11;" value="Self-Employment Net Income" vertex="1">
          <mxGeometry height="50" width="220" x="260" y="62" as="geometry" />
        </mxCell>
        <mxCell id="cg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=11;" value="Capital Gains" vertex="1">
          <mxGeometry height="50" width="220" x="500" y="62" as="geometry" />
        </mxCell>
        <mxCell id="other" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=11;" value="Other Income" vertex="1">
          <mxGeometry height="50" width="240" x="740" y="62" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="2  .  MANDATORY WITHHOLDINGS  (calculated before any optimization)" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="148" as="geometry" />
        </mxCell>
        <mxCell id="t4cpp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="T4 CPP - Tier 1 + Tier 2&#xa;Pensionable earnings on T4 up to YMPE (Tier 1)&#xa;and YMPE to YAMPE band (Tier 2)&#xa;base portion: Line 30800 (NR credit)&#xa;enhanced portion: Line 22215 (income deduction)" vertex="1">
          <mxGeometry height="100" width="300" x="20" y="190" as="geometry" />
        </mxCell>
        <mxCell id="ei" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;" value="EI Premium&#xa;min( min(T4, maxInsurable) x rate, maxPremium )&#xa;T4 employment only; SE EI excluded&#xa;Line 31200 (NR credit)" vertex="1">
          <mxGeometry height="100" width="300" x="340" y="190" as="geometry" />
        </mxCell>
        <mxCell id="secpp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="SE CPP - Tier 1 + Tier 2&#xa;T4 consumes YMPE / YAMPE headroom first&#xa;SE pays both employee + employer halves&#xa;50% of seCpp1: Line 22200 (income deduction)&#xa;enhanced portion: Line 22215 (income deduction)&#xa;base portion: Line 31000 (NR credit)" vertex="1">
          <mxGeometry height="100" width="320" x="660" y="190" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="3  .  INCOME AGGREGATION" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="328" as="geometry" />
        </mxCell>
        <mxCell id="cginc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" value="Capital Gains Inclusion Rate&#xa;up to $250K: CG x 50%  |  above $250K: $125K + excess x 2/3" vertex="1">
          <mxGeometry height="50" width="450" x="20" y="368" as="geometry" />
        </mxCell>
        <mxCell id="tgi" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=11;" value="taxableGrossIncome = T4 + SE + Other + cgInclusion" vertex="1">
          <mxGeometry height="50" width="490" x="490" y="368" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="4  .  DEDUCTIONS FROM INCOME  -  netIncome  (CRA Line 23600)" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="456" as="geometry" />
        </mxCell>
        <mxCell id="ni" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" value="netIncome = taxableGrossIncome&#xa;   -  SE CPP employer deduction          (Line 22200)&#xa;   -  SE CPP enhanced deduction           (Line 22215)&#xa;   -  T4 CPP enhanced + Tier 2             (Line 22215)&#xa;   -  FHSA contributions (already + new)   (Line 20805)&#xa;   -  RRSP contributions                   (Line 20800)&#xa;   -  Childcare                            (Line 21400)&#xa;&#xa;Before optimization: only CPP lines apply; FHSA + RRSP = $0" vertex="1">
          <mxGeometry height="120" width="960" x="20" y="496" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="5  .  TAX CALCULATIONS  (applied to netIncome)" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="654" as="geometry" />
        </mxCell>
        <mxCell id="fedt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" value="FEDERAL TAX&#xa;rawFed = bracketedTax(netIncome, FED_BRACKETS)&#xa;&#xa;Non-refundable credits at first bracket rate (~14%):&#xa;  BPA credit  |  CPP NR credit (L30800 + L31000)&#xa;  EI credit  |  Canada Employment Amount  |  Medical&#xa;&#xa;fedTax = max(0, rawFed - credits)" vertex="1">
          <mxGeometry height="130" width="460" x="20" y="694" as="geometry" />
        </mxCell>
        <mxCell id="provt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" value="PROVINCIAL TAX  (BC example)&#xa;rawProv = bracketedTax(netIncome, PROV_BRACKETS)&#xa;&#xa;Non-refundable credits at lowest prov rate (~5.6% BC):&#xa;  Prov BPA  |  CPP / EI credits&#xa;  BC Low-Income Tax Reduction (LITR):&#xa;    up to $690 credit; claws back 3.56% above $25,570&#xa;  Medical credit (at prov rate)&#xa;&#xa;adjProvTax = max(0, rawProv - credits)" vertex="1">
          <mxGeometry height="130" width="480" x="500" y="694" as="geometry" />
        </mxCell>
        <mxCell id="ttax" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="totalTax  =  fedTax  +  adjProvTax" vertex="1">
          <mxGeometry height="36" width="960" x="20" y="834" as="geometry" />
        </mxCell>
        <mxCell id="s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#6d4a87;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="6  .  BEFORE OPTIMIZATION  -  baseline snapshot  (rrsp = $0, fhsa = $0)" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="906" as="geometry" />
        </mxCell>
        <mxCell id="b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="taxOwing&#xa;= max(0, totalTax - t4TotalTax)&#xa;April balance owing" vertex="1">
          <mxGeometry height="70" width="220" x="20" y="946" as="geometry" />
        </mxCell>
        <mxCell id="b2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="afterTaxIncome&#xa;= grossIncome - totalTax - totalCpp - EI&#xa;Take-home income" vertex="1">
          <mxGeometry height="70" width="250" x="260" y="946" as="geometry" />
        </mxCell>
        <mxCell id="b3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="avgTaxRate&#xa;= (totalTax + totalCpp + EI) / grossIncome" vertex="1">
          <mxGeometry height="70" width="250" x="530" y="946" as="geometry" />
        </mxCell>
        <mxCell id="b4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="marginalRateBefore&#xa;Probe: singlePass(+$100) - base&#xa;Chart cursor: beforePass.netIncome" vertex="1">
          <mxGeometry height="70" width="180" x="800" y="946" as="geometry" />
        </mxCell>
        <mxCell id="s7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="7  .  OPTIMIZATION CONSTRAINTS" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="1054" as="geometry" />
        </mxCell>
        <mxCell id="o1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="Available Cash / month&#xa;x 12 = annual budget" vertex="1">
          <mxGeometry height="56" width="220" x="20" y="1094" as="geometry" />
        </mxCell>
        <mxCell id="o2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="FHSA Room&#xa;min(roomForYear - alreadyContrib,&#xa;lifetimeLimit - lifetimeUsed)" vertex="1">
          <mxGeometry height="56" width="220" x="260" y="1094" as="geometry" />
        </mxCell>
        <mxCell id="o3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="RRSP Room&#xa;roomFromNOA - alreadyContrib&#xa;- RRSP match impact" vertex="1">
          <mxGeometry height="56" width="220" x="500" y="1094" as="geometry" />
        </mxCell>
        <mxCell id="o4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="Optimization Floor&#xa;BC: $21,000 fixed&#xa;AB / SK: fed BPA for year&#xa;netIncome never drops below this" vertex="1">
          <mxGeometry height="56" width="240" x="740" y="1094" as="geometry" />
        </mxCell>
        <mxCell id="s8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#fff;fontStyle=1;fontSize=12;align=center;" value="8  .  5-PASS CONVERGENCE LOOP  -  RRSP is self-referential: more contribution, less tax, more cash, more contribution" vertex="1">
          <mxGeometry height="30" width="960" x="20" y="1186" as="geometry" />
        </mxCell>
        <mxCell id="l1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="1. Run singlePass&#xa;with current rrsp + fhsa&#xa;Start: rrsp=0, fhsa=0" vertex="1">
          <mxGeometry height="80" width="160" x="20" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="l2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="2. taxOwing&#xa;= max(0, totalTax&#xa;  - t4TotalTax)" vertex="1">
          <mxGeometry height="80" width="170" x="200" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="l3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="3. Investable pool&#xa;= cash - taxOwing&#xa;  - seCpp" vertex="1">
          <mxGeometry height="80" width="160" x="390" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="l4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="4. FHSA first&#xa;= min(pool, fhsaRoom)&#xa;Filled before RRSP" vertex="1">
          <mxGeometry height="80" width="150" x="570" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="l5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="5. RRSP headroom&#xa;= netIncome + prior contribs&#xa;  - new fhsa - floor" vertex="1">
          <mxGeometry height="80" width="160" x="740" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="l6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#6d4a87;fontColor=#fff;fontSize=10;" value="6. RRSP amount&#xa;= min(pool - fhsa,&#xa;  rrspRoom, headroom)&#xa;feeds back to step 1" vertex="1">
          <mxGeometry height="80" width="160" x="820" y="1230" as="geometry" />
