        <mxCell id="loopback" edge="1" parent="1" source="l6" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#9673A6;fontStyle=2;fontSize=10;endArrow=block;endFill=1;" target="l1" value="passes 1 through 4: repeat with updated rrsp + fhsa">
